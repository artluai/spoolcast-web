{
  "adapter": "news-anime-bot",
  "summary": "Show-specific mobile-first AI news satire pipeline: sourced story to 12-beat script, generated clips, Schedar TTS, ffmpeg stitch, platform package.",
  "session_root": "../spoolcast-content/shows/news-anime-bot/sessions/{session_id}",
  "source_of_truth": [
    "episode/script.md",
    "episode/run_clips.py",
    "episode/run_tts_schedar.py",
    "episode/run_stitch.py",
    "cast.txt"
  ],
  "context_gate_schema_version": 1,
  "context_gates": [
    {
      "id": "news_source_context",
      "stage": "input_intake",
      "applies_to_actions": ["gather_sources"],
      "purpose": "Force show rules, topic-risk rules, and current source material before fact gathering.",
      "required_sources": [
        "rules.md",
        "contracts/news-anime-bot.json",
        "PIPELINE.md",
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/platform-notes.md",
        "candidate story brief",
        "current source URLs",
        "current date"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/working/source-facts.md",
        "<session_root>/episode/script.md:## Sources"
      ],
      "downstream_checks": [
        "planned: source receipt is current before story_lock and script"
      ]
    },
    {
      "id": "topic_story_context",
      "stage": "story_lock",
      "applies_to_actions": ["classify_topic", "draft_headline"],
      "purpose": "Force factual sources and platform-risk rules before selecting the headline and topic tier.",
      "required_sources": [
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/platform-notes.md",
        "<session_root>/working/source-facts.md",
        "<session_root>/working/.rule-gates/news_source_context.json",
        "current source URLs",
        "current date"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/working/topic-risk.md",
        "<session_root>/working/headline.md"
      ],
      "downstream_checks": [
        "planned: topic receipt is current before visual story structure"
      ]
    },
    {
      "id": "visual_story_context",
      "stage": "structure",
      "applies_to_actions": ["plan_visual_story", "select_cast"],
      "purpose": "Force show style, character registry, topic risk, and facts before the 12-beat visual plan.",
      "required_sources": [
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/characters.md",
        "../spoolcast-content/shows/news-anime-bot/platform-notes.md",
        "VIDEO_OUTPUT_RULES.md",
        "<session_root>/working/source-facts.md",
        "<session_root>/working/topic-risk.md",
        "<session_root>/working/headline.md",
        "<session_root>/working/.rule-gates/topic_story_context.json",
        "../spoolcast-content/shows/news-anime-bot/characters/*.png"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/working/visual-story-plan.md",
        "<session_root>/working/selected-cast.md"
      ],
      "downstream_checks": [
        "planned: visual story receipt is current before script and clip plan"
      ]
    },
    {
      "id": "news_script_context",
      "stage": "script",
      "applies_to_actions": ["write_script"],
      "purpose": "Force facts, visual story, show rules, and compiled narration voice before writing episode/script.md.",
      "required_sources": [
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/NARRATION_VOICE.md",
        "../spoolcast-content/shows/news-anime-bot/platform-notes.md",
        "VIDEO_OUTPUT_RULES.md",
        "<session_root>/working/source-facts.md",
        "<session_root>/working/topic-risk.md",
        "<session_root>/working/headline.md",
        "<session_root>/working/visual-story-plan.md",
        "<session_root>/working/selected-cast.md",
        "<session_root>/working/.rule-gates/visual_story_context.json",
        "current source URLs"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/episode/script.md"
      ],
      "downstream_checks": [
        "audit_narration_voice.py",
        "spoolcast_audit.py",
        "planned: script receipt is current before audio and clip plan"
      ]
    },
    {
      "id": "clip_plan_context",
      "stage": "production_units",
      "applies_to_actions": ["write_clip_plan"],
      "purpose": "Force script, character registry, selected cast, and engine rules before writing model prompts in run_clips.py.",
      "required_sources": [
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/characters.md",
        "VIDEO_OUTPUT_RULES.md",
        "<session_root>/episode/script.md",
        "<session_root>/working/selected-cast.md",
        "<session_root>/working/.rule-gates/news_script_context.json",
        "../spoolcast-content/shows/news-anime-bot/characters/*.png",
        "../spoolcast-content/shows/news-anime-bot/refs/*"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/episode/run_clips.py",
        "<session_root>/cast.txt"
      ],
      "downstream_checks": [
        "planned: prompt scanner rejects real names in model prompt strings",
        "planned: cast manifest resolves every selected character"
      ]
    },
    {
      "id": "news_output_review_context",
      "stage": "output_audit",
      "applies_to_actions": ["review_final_mp4"],
      "purpose": "Force final output reviewers to check platform disclosure, captions, watermark, chyrons, source framing, and cast continuity.",
      "required_sources": [
        "../spoolcast-content/shows/news-anime-bot/rules.md",
        "../spoolcast-content/shows/news-anime-bot/platform-notes.md",
        "../spoolcast-content/shows/news-anime-bot/characters.md",
        "<session_root>/episode/script.md",
        "<session_root>/episode/run_clips.py",
        "<session_root>/episode/run_stitch.py",
        "<session_root>/cast.txt",
        "<session_root>/episode/out/*.mp4",
        "<session_root>/episode/out/*.srt"
      ],
      "receipt_required_for_outputs": [
        "<session_root>/working/output-audit.md"
      ],
      "downstream_checks": [
        "planned: publish requires output-audit receipt and explicit approval"
      ]
    }
  ],
  "statuses": [
    "not_started",
    "ready",
    "running",
    "blocked",
    "failed",
    "passed",
    "approved",
    "skipped"
  ],
  "stages": [
    {
      "id": "bootstrap_episode",
      "label": "Bootstrap Episode",
      "owner": "script",
      "requires_approval": true,
      "inputs": [
        "prior episode folder",
        "episode date"
      ],
      "outputs": [
        "episode/script.md",
        "episode/run_clips.py",
        "episode/run_tts_schedar.py",
        "episode/run_stitch.py"
      ],
      "gate": "stable episode files exist and are non-empty",
      "actions": [
        "copy_prior_episode"
      ]
    },
    {
      "id": "input_intake",
      "label": "News Source Intake",
      "owner": "ai",
      "requires_approval": false,
      "inputs": [
        "candidate story",
        "source URLs"
      ],
      "outputs": [
        "source/fact list"
      ],
      "gate": "source URLs and facts exist before scripting",
      "actions": [
        "gather_sources"
      ]
    },
    {
      "id": "story_lock",
      "label": "Topic / Story Lock",
      "owner": "ai",
      "requires_approval": true,
      "inputs": [
        "source/fact list"
      ],
      "outputs": [
        "headline",
        "topic-risk classification"
      ],
      "gate": "topic is green/yellow and headline is factual",
      "actions": [
        "classify_topic",
        "draft_headline"
      ]
    },
    {
      "id": "structure",
      "label": "Visual Story Structure",
      "owner": "ai",
      "requires_approval": true,
      "inputs": [
        "headline",
        "story absurdity"
      ],
      "outputs": [
        "12-beat visual story plan",
        "selected cast"
      ],
      "gate": "12-beat plan exists and selected locked characters are justified",
      "actions": [
        "plan_visual_story",
        "select_cast"
      ]
    },
    {
      "id": "script",
      "label": "Script",
      "owner": "ai",
      "requires_approval": false,
      "inputs": [
        "12-beat visual story plan",
        "sources"
      ],
      "outputs": [
        "episode/script.md",
        "episode/narration-voice-review.json"
      ],
      "gate": "script has narration, sources, audit notes, narrator-only delivery, and narration voice audit has no blocking flags",
      "actions": [
        "write_script",
        "audit_narration_voice"
      ]
    },
    {
      "id": "production_units",
      "label": "Clip Plan",
      "owner": "ai+script",
      "requires_approval": false,
      "inputs": [
        "episode/script.md",
        "selected cast"
      ],
      "outputs": [
        "episode/run_clips.py"
      ],
      "gate": "every beat has duration intent, prompt, model choice, and character refs if needed",
      "actions": [
        "write_clip_plan"
      ]
    },
    {
      "id": "audio",
      "label": "Narration Audio",
      "owner": "script",
      "requires_approval": false,
      "inputs": [
        "episode/script.md",
        "episode/narration-voice-review.json",
        "episode/run_tts_schedar.py"
      ],
      "outputs": [
        "episode/audio/*.mp3",
        "episode/audio/*.timepoints.json"
      ],
      "gate": "at least 12 narration mp3 files exist and ffprobe succeeds",
      "actions": [
        "run_tts_schedar",
        "ffprobe_audio"
      ]
    },
    {
      "id": "visual_clips",
      "label": "Visual Clips",
      "owner": "script",
      "requires_approval": false,
      "inputs": [
        "episode/run_clips.py",
        "episode/audio/*.mp3"
      ],
      "outputs": [
        "episode/clips/*.mp4"
      ],
      "gate": "every beat has usable visual clip or cutaway asset",
      "actions": [
        "run_clips"
      ]
    },
    {
      "id": "asset_audit",
      "label": "Clip Review",
      "owner": "human+ai",
      "requires_approval": true,
      "inputs": [
        "episode/clips/*.mp4"
      ],
      "outputs": [
        "approved clip set or regeneration notes"
      ],
      "gate": "no known failed clip is carried silently",
      "actions": [
        "review_clips",
        "regenerate_failed_clips"
      ]
    },
    {
      "id": "assembly",
      "label": "Stitch",
      "owner": "script",
      "requires_approval": false,
      "inputs": [
        "episode/clips/*.mp4",
        "episode/audio/*.mp3",
        "episode/run_stitch.py"
      ],
      "outputs": [
        "episode/out/*.mp4",
        "episode/out/*.srt"
      ],
      "gate": "final mp4 and srt exist",
      "actions": [
        "run_stitch"
      ]
    },
    {
      "id": "output_audit",
      "label": "Output Audit",
      "owner": "human+ai",
      "requires_approval": true,
      "inputs": [
        "episode/out/*.mp4"
      ],
      "outputs": [
        "approved final output"
      ],
      "gate": "pacing, captions, watermark, disclosure, chyrons, and audio are approved",
      "actions": [
        "review_final_mp4"
      ]
    },
    {
      "id": "cast_manifest",
      "label": "Cast Manifest",
      "owner": "script",
      "requires_approval": false,
      "inputs": [
        "selected cast"
      ],
      "outputs": [
        "cast.txt"
      ],
      "gate": "cast.txt has one used character name per line",
      "actions": [
        "write_cast_manifest"
      ]
    },
    {
      "id": "publish",
      "label": "Publish / Package",
      "owner": "human+script",
      "requires_approval": true,
      "inputs": [
        "approved final output",
        "cast.txt"
      ],
      "outputs": [
        "platform URL or package folder"
      ],
      "gate": "explicit platform approval, disclosure toggles, caption/comment disclosure, SRT upload, and account-status check",
      "actions": [
        "manual_publish"
      ]
    }
  ]
}
